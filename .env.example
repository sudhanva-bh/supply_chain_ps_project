# LLM_PROVIDER can be 'google' or 'openai'
LLM_PROVIDER=google

# For LLM_PROVIDER=google
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_MODEL_NAME=gemini-flash-lite-latest

# For LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-5-mini

# MCP Server Configuration
GILHARI_BASE_URL=http://localhost:80/gilhari/v1/
GILHARI_HOST=localhost
GILHARI_PORT=80
MCP_SERVER_NAME=SupplyChainMCP

APP_PASSWORD=secret123

# Azure SQL Database Credentials for raw SQL execution
AZURE_SQL_SERVER=your_azure_sql_server.database.windows.net
AZURE_SQL_DATABASE=YourDatabaseName
AZURE_SQL_USER=your_db_user
AZURE_SQL_PASSWORD=your_db_password

# JDX ORM Connection String
JDBC_URL=jdbc:sqlserver://your_azure_sql_server.database.windows.net:1433;databaseName=YourDatabaseName;encrypt=true;trustServerCertificate=false;hostNameInCertificate=*.database.windows.net;loginTimeout=30;USER=your_db_user;PASSWORD=your_db_password;JDX_DBTYPE=SQLSERVER;DEBUG_LEVEL=5
